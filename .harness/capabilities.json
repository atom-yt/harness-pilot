  "code_templates": {
    "enabled": false
  },
  "refactor": {
    "enabled": false
  },
  "e2e": {
    "enabled": false
  },
  "monitoring": {
    "enabled": false,
    "provider": null
  },
  "security": {
    "enabled": false,
    "sast_tool": null
  }
}