{
  "version": "1.0.0",
  "developmentMode": {
    "default": "spec",
    "enforceSDDPipeline": true,
    "strictOrder": true,
    "allowSkipForTrivial": true,
    "trivialThreshold": 6
  },
  "qualityRules": {
    "noConsoleLog": true,
    "maxFileSize": 500,
    "typescriptStrictMode": true,
    "noHardcodedStrings": false,
    "java": {
      "maxMethodLines": 50,
      "maxClassLines": 500,
      "checkstyleEnabled": true,
      "useLombok": false
    }
  },
  "loop": {
    "maxIterations": 3,
    "autoFixEnabled": true,
    "recordTrace": true
  },
  "capabilities": {
    "jitTest": false,
    "codeTemplates": true,
    "refactoring": false,
    "e2e": false,
    "security": false,
    "monitoring": false
  },
  "superpowers": {
    "recommended": [
      "brainstorm",
      "planning",
      "tdd",
      "code-reviewer",
      "git-worktree"
    ]
  }
}