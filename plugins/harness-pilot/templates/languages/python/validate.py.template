#!/usr/bin/env python3
"""
Unified Validation Pipeline
Runs all validation steps in order

Usage: python .harness/scripts/validate.py [--step <name>]
"""

import subprocess
import sys
import time
from dataclasses import dataclass
from typing import List, Optional

# ============================================================================
# Configuration
# ============================================================================

@dataclass
class CapabilityConfig:
    jit_test_enabled: bool = False
    jit_test_auto_generate: bool = False
    refactor_enabled: bool = False
    security_enabled: bool = False
    e2e_api_enabled: bool = False
    e2e_browser_enabled: bool = False


@dataclass
class ValidationStep:
    name: str
    description: str
    command: str
    timeout: int = 120
    skip_if_missing: Optional[List[str]] = None
    skip_if_no_test: bool = False


# Load capabilities configuration if exists
def load_capabilities() -> CapabilityConfig:
    try:
        import json
        from pathlib import Path
        capabilities_path = Path('.harness/capabilities.json')
        if capabilities_path.exists():
            with open(capabilities_path) as f:
                data = json.load(f)
                caps = data.get('capabilities', {})
                return CapabilityConfig(
                    jit_test_enabled=caps.get('jit_test', {}).get('enabled', False),
                    jit_test_auto_generate=caps.get('jit_test', {}).get('auto_generate_on_pr', False),
                    refactor_enabled=caps.get('refactor', {}).get('enabled', False),
                    security_enabled=caps.get('security', {}).get('enabled', False),
                    e2e_api_enabled=caps.get('e2e', {}).get('api_e2e_enabled', False),
                    e2e_browser_enabled=caps.get('e2e', {}).get('browser_e2e_enabled', False),
                )
    except Exception:
        pass
    return CapabilityConfig()


CAPABILITIES = load_capabilities()

VALIDATION_STEPS: List[ValidationStep] = [
    ValidationStep(
        name='build',
        description='Build project',
        command='python -m pip install -e .',
        timeout=120,
        skip_if_missing=['setup.py', 'pyproject.toml'],
    ),
    ValidationStep(
        name='lint-arch',
        description='Architecture lint',
        command='python .harness/scripts/lint-deps.py',
        timeout=60,
    ),
    ValidationStep(
        name='lint-quality',
        description='Quality lint',
        command='python .harness/scripts/lint-quality.py',
        timeout=60,
    ),
    *([] if not CAPABILITIES.security_enabled else [
        ValidationStep(
            name='security-scan',
            description='Security scan',
            command='bash .harness/scripts/security-scan.sh .',
            timeout=60,
        ),
    ]),
    ValidationStep(
        name='test',
        description='Run tests',
        command='pytest',
        timeout=300,
    ),
    *([] if not CAPABILITIES.jit_test_enabled else [
        ValidationStep(
            name='jit-test-generate',
            description='JiT test generation',
            command='bash .harness/scripts/generate-test.sh',
            timeout=60,
        ),
    ]),
    *([] if not CAPABILITIES.e2e_api_enabled else [
        ValidationStep(
            name='e2e-api',
            description='API E2E tests',
            command='python .harness/e2e/e2e-api.py',
            timeout=180,
        ),
    ]),
    *([] if not CAPABILITIES.e2e_browser_enabled else [
        ValidationStep(
            name='e2e-browser',
            description='Browser E2E tests',
            command='playwright test .harness/e2e/e2e-browser.spec.ts',
            timeout=300,
        ),
    ]),
]


# ============================================================================
# Result Classes
# ============================================================================

@dataclass
class StepResult:
    name: str
    success: bool
    duration: float
    skipped: bool = False
    output: Optional[str] = None
    error: Optional[str] = None


# ============================================================================
# Runner
# ============================================================================

def should_skip_step(step: ValidationStep) -> bool:
    """Check if a step should be skipped."""
    import os
    from pathlib import Path

    if step.skip_if_missing:
        for file in step.skip_if_missing:
            if not Path(file).exists():
                print(f'   ⊘ {step.name} skipped ({file} not found)')
                return True
    if step.skip_if_no_test:
        # Check for Python test configuration
        has_tests = (
            # Standard test directories
            Path('tests').exists() or Path('test').exists() or
            # Test configuration files
            Path('pytest.ini').exists() or Path('pyproject.toml').exists() or
            Path('setup.cfg').exists() or Path('tox.ini').exists() or
            # Test in src/tests or src/test directories
            Path('src/tests').exists() or Path('src/test').exists()
        )

        # Check for test files (wrap in try-except for permission errors)
        if not has_tests:
            try:
                has_test_files = (
                    any(f.name.startswith('test_') for f in Path('.').iterdir() if f.is_file()) or
                    any(f.name.endswith('_test.py') for f in Path('.').iterdir() if f.is_file())
                )
                has_tests = has_tests or has_test_files
            except (PermissionError, OSError):
                # If we can't read the directory, assume tests might exist
                pass

        if not has_tests:
            print(f'   ⊘ {step.name} skipped (no tests found)')
            return True
    return False


def run_step(step: ValidationStep) -> StepResult:
    """Run a single validation step."""
    if should_skip_step(step):
        return StepResult(
            name=step.name,
            success=True,
            skipped=True,
            duration=0,
        )

    start = time.time()

    print(f'\n🔧 Running {step.name}...')
    print(f'   Command: {step.command}')

    try:
        result = subprocess.run(
            step.command,
            shell=True,
            timeout=step.timeout,
            capture_output=True,
            text=True,
        )

        duration = round(time.time() - start)

        if result.returncode == 0:
            print(f'   ✓ {step.name} passed ({duration}s)')
            return StepResult(
                name=step.name,
                success=True,
                duration=duration,
                output=result.stdout,
            )
        else:
            print(f'   ✗ {step.name} failed ({duration}s)')
            if result.stderr:
                print(f'   Error: {result.stderr[:200]}')
            return StepResult(
                name=step.name,
                success=False,
                duration=duration,
                error=result.stderr or result.stdout,
            )

    except subprocess.TimeoutExpired:
        duration = round(time.time() - start)
        print(f'   ✗ {step.name} timed out ({duration}s)')
        return StepResult(
            name=step.name,
            success=False,
            duration=duration,
            error=f'Timeout after {step.timeout}s',
        )
    except Exception as e:
        duration = round(time.time() - start)
        print(f'   ✗ {step.name} failed ({duration}s)')
        return StepResult(
            name=step.name,
            success=False,
            duration=duration,
            error=str(e),
        )


def main() -> None:
    """Main entry point."""
    print('\n' + '═' * 55)
    print('          Harness Validation Pipeline')
    print('═' * 55 + '\n')

    results: List[StepResult] = []
    step_filter = None

    # Parse --step argument
    for i, arg in enumerate(sys.argv[1:], start=1):
        if arg == '--step' and i < len(sys.argv) - 1:
            step_filter = sys.argv[i + 1]
            break

    for step in VALIDATION_STEPS:
        if step_filter and step.name != step_filter:
            continue

        result = run_step(step)
        results.append(result)

        if not result.success:
            print(f'\n❌ Validation failed at step: {step.name}')
            if result.error:
                print(f'   {result.error}\n')
            sys.exit(1)

    # Summary
    total_duration = sum(r.duration for r in results)
    print('\n' + '═' * 55)
    print('                Validation Summary')
    print('═' * 55 + '\n')

    for result in results:
        if result.skipped:
            print(f'  ⊘ {result.name.ljust(15)} skipped')
        else:
            icon = '✓' if result.success else '✗'
            print(f'  {icon} {result.name.ljust(15)} {result.duration}s')

    print(f'\n  Total: {total_duration}s')
    print('═' * 55 + '\n')

    print('✓ All validation steps passed!\n')
    sys.exit(0)


if __name__ == '__main__':
    main()