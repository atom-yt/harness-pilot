#!/usr/bin/env go run
// +build ignore

package main

import (
	"flag"
	"fmt"
	"os"
	"os/exec"
	"strings"
	"time"
)

// ============================================================================
// Data Structures
// ============================================================================

type ValidationStep struct {
	Name        string
	Description string
	Command     string
	Timeout     time.Duration
}

type StepResult struct {
	Name     string
	Success  bool
	Duration time.Duration
	Output   string
	Error    string
}

// ============================================================================
// Configuration
// ============================================================================

type CapabilityConfig struct {
	JitTestEnabled      bool
	RefactorEnabled     bool
	SecurityEnabled     bool
	E2EAPIEnabled      bool
	E2EBrowserEnabled  bool
}

// Load capabilities from .harness/capabilities.json if exists
func loadCapabilities() CapabilityConfig {
	config := CapabilityConfig{}

	data, err := os.ReadFile(".harness/capabilities.json")
	if err != nil {
		return config
	}

	// Simple JSON parsing for capabilities
	// In production, use encoding/json for proper parsing
	content := string(data)
	if strings.Contains(content, `"jit_test"`) && strings.Contains(content, `"enabled":true`) {
		config.JitTestEnabled = true
	}
	if strings.Contains(content, `"refactor"`) && strings.Contains(content, `"enabled":true`) {
		config.RefactorEnabled = true
	}
	if strings.Contains(content, `"security"`) && strings.Contains(content, `"enabled":true`) {
		config.SecurityEnabled = true
	}
	if strings.Contains(content, `"api_e2e_enabled":true`) {
		config.E2EAPIEnabled = true
	}
	if strings.Contains(content, `"browser_e2e_enabled":true`) {
		config.E2EBrowserEnabled = true
	}

	return config
}

var CAPABILITIES = loadCapabilities()

var VALIDATION_STEPS = []ValidationStep{
	{
		Name:        "build",
		Description: "Build project",
		Command:     "go build ./...",
		Timeout:     2 * time.Minute,
	},
	{
		Name:        "lint-arch",
		Description: "Architecture lint",
		Command:     "go run .harness/scripts/lint-deps.go",
		Timeout:     1 * time.Minute,
	},
	{
		Name:        "lint-quality",
		Description: "Quality lint",
		Command:     "go run .harness/scripts/lint-quality.go",
		Timeout:     1 * time.Minute,
	},
}

// ============================================================================
// Runner
// ============================================================================

func runStep(step ValidationStep) StepResult {
	start := time.Now()

	fmt.Printf("\n🔧 Running %s...\n", step.Name)
	fmt.Printf("   Command: %s\n", step.Command)

	// Create command
	cmd := exec.Command("sh", "-c", step.Command)

	// Capture output
	output, err := cmd.CombinedOutput()

	duration := time.Since(start)

	if err != nil {
		fmt.Printf("   ✗ %s failed (%.0fs)\n", step.Name, duration.Seconds())
		if len(output) > 0 {
			fmt.Printf("   Error: %s\n", strings.TrimSpace(string(output)[:200]))
		}
		return StepResult{
			Name:     step.Name,
			Success:  false,
			Duration: duration,
			Output:   string(output),
			Error:    err.Error(),
		}
	}

	fmt.Printf("   ✓ %s passed (%.0fs)\n", step.Name, duration.Seconds())

	return StepResult{
		Name:     step.Name,
		Success:  true,
		Duration: duration,
		Output:   string(output),
	}
}

// ============================================================================
// Build validation steps based on capabilities
// ============================================================================

func buildValidationSteps() []ValidationStep {
	steps := []ValidationStep{
		{
			Name:        "build",
			Description: "Build project",
			Command:     "go build ./...",
			Timeout:     2 * time.Minute,
		},
		{
			Name:        "lint-arch",
			Description: "Architecture lint",
			Command:     "go run .harness/scripts/lint-deps.go",
			Timeout:     1 * time.Minute,
		},
		{
			Name:        "lint-quality",
			Description: "Quality lint",
			Command:     "go run .harness/scripts/lint-quality.go",
			Timeout:     1 * time.Minute,
		},
	}

	// Add optional steps based on capabilities
	if CAPABILITIES.SecurityEnabled {
		steps = append(steps, ValidationStep{
			Name:        "security-scan",
			Description: "Security scan",
			Command:     "bash .harness/scripts/security-scan.sh .",
			Timeout:     1 * time.Minute,
		})
	}

	steps = append(steps, ValidationStep{
		Name:        "test",
		Description: "Run tests",
		Command:     "go test ./...",
		Timeout:     5 * time.Minute,
	})

	if CAPABILITIES.JitTestEnabled {
		steps = append(steps, ValidationStep{
			Name:        "jit-test-generate",
			Description: "JiT test generation",
			Command:     "bash .harness/scripts/generate-test.sh",
			Timeout:     1 * time.Minute,
		})
	}

	if CAPABILITIES.E2EAPIEnabled {
		steps = append(steps, ValidationStep{
			Name:        "e2e-api",
			Description: "API E2E tests",
			Command:     "go run .harness/e2e/e2e-api.go",
			Timeout:     3 * time.Minute,
		})
	}

	if CAPABILITIES.E2EBrowserEnabled {
		steps = append(steps, ValidationStep{
			Name:        "e2e-browser",
			Description: "Browser E2E tests",
			Command:     "go test .harness/e2e/e2e-browser_test.go",
			Timeout:     5 * time.Minute,
		})
	}

	return steps
}

// ============================================================================
// Main
// ============================================================================

func main() {
	// Parse --step argument
	stepFilter := ""
	for i, arg := range os.Args[1:] {
		if arg == "--step" && i < len(os.Args)-2 {
			stepFilter = os.Args[i+2]
			break
		}
	}

	fmt.Println("\n" + strings.Repeat("═", 55))
	fmt.Println("          Harness Validation Pipeline")
	fmt.Println(strings.Repeat("═", 55) + "\n")

	var results []StepResult

	validationSteps := buildValidationSteps()

	for _, step := range validationSteps {
		if stepFilter != "" && step.Name != stepFilter {
			continue
		}

		result := runStep(step)
		results = append(results, result)

		if !result.Success {
			fmt.Printf("\n❌ Validation failed at step: %s\n", step.Name)
			if result.Error != "" {
				fmt.Printf("   %s\n\n", result.Error)
			}
			os.Exit(1)
		}
	}

	// Summary
	var totalDuration time.Duration
	for _, r := range results {
		totalDuration += r.Duration
	}

	fmt.Println("\n" + strings.Repeat("═", 55))
	fmt.Println("                Validation Summary")
	fmt.Println(strings.Repeat("═", 55) + "\n")

	for _, result := range results {
		icon := "✓"
		if !result.Success {
			icon = "✗"
		}
		fmt.Printf("  %s %-15s %.0fs\n", icon, result.Name+":", result.Duration.Seconds())
	}

	fmt.Printf("\n  Total: %.0fs\n", totalDuration.Seconds())
	fmt.Println(strings.Repeat("═", 55) + "\n")

	fmt.Println("✓ All validation steps passed!\n")
	os.Exit(0)
}