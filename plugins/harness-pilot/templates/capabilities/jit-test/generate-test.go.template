#!/usr/bin/env bash
# JiT Test Generator for Go
# Generates comprehensive test cases for analyzed functions

set -euo pipefail

# ============================================================================
# Configuration
# ============================================================================

COVERAGE_THRESHOLD=${COVERAGE_THRESHOLD:-80}
MAX_TESTS_PER_FUNCTION=${MAX_TESTS_PER_FUNCTION:-5}
TEST_FRAMEWORK=${TEST_FRAMEWORK:-go-test}

# ============================================================================
# AST Analysis (using go AST)
# ============================================================================

analyze_go_functions() {
  local file=$1

  # Extract function signatures using gofmt -s and grep
  gofmt -s "$file" | grep -E '^\s*(func\s+\(\s*\w+\s+\*?\w+\s*\)\s+)?\w+\s*\(' | \n    sed 's/^.*func\(\s\+\(.*\)\)\? \([^ (]*\).*/\3/' | \n    grep -v "^func$" || echo ""
}

analyze_go_branches() {
  local file=$1

  # Count if, switch, and for statements
  local if_count=$(grep -c '\bif ' "$file" 2>/dev/null || echo "0")
  local switch_count=$(grep -c '\bswitch ' "$file" 2>/dev/null || echo "0")
  local for_count=$(grep -c '\bfor ' "$file" 2>/dev/null || echo "0")

  echo "if: $if_count, switch: $switch_count, for: $for_count"
}

# ============================================================================
# Test Generation
# ============================================================================

generate_go_test_file() {
  local source_file=$1
  local output_file=$2

  # Extract package name
  local package=$(grep '^package ' "$source_file" | head -1 | awk '{print $2}')

  # Extract functions
  local functions=$(analyze_go_functions "$source_file")

  cat > "$output_file" << EOF
// Generated by JiT Test Generator
// Source: $source_file

package $(echo "$package" | tr '[:lower:]' '[:upper:]')

import (
  "testing"
)

EOF

  # Generate tests for each function
  for fn in $functions; do
    if [[ "$fn" =~ ^[A-Z] ]]; then  # Exported functions only
      generate_go_test_function "$fn" >> "$output_file"
    fi
  done

  echo "âś“ Generated: $output_file"
}

generate_go_test_function() {
  local fn_name=$1

  cat << EOF

func Test${fn_name}Normal(t *testing.T) {
    // Normal path test
    t.Run("normal", func(t *testing.T) {
        // Arrange & Act & Assert
        // TODO: Implement test for ${fn_name}
        t.Skip("Implement me")
    })
}

func Test${fn_name}Boundary(t *testing.T) {
    // Boundary value test
    t.Run("boundary", func(t *testing.T) {
        // TODO: Implement boundary test for ${fn_name}
        t.Skip("Implement me")
    })
}

func Test${fn_name}Error(t *testing.T) {
    // Error handling test
    t.Run("error", func(t *testing.T) {
        // TODO: Implement error test for ${fn_name}
        t.Skip("Implement me")
    })
}
EOF
}

# ============================================================================
# CLI Interface
# ============================================================================

main() {
  local source_file=$1
  local output_file=${2:-}

  if [[ -z "$source_file" ]]; then
    echo "Usage: $0 <source-file.go> [output-file.go]"
    exit 1
  fi

  if [[ ! -f "$source_file" ]]; then
    echo "Error: Source file not found: $source_file"
    exit 1
  fi

  if [[ -z "$output_file" ]]; then
    output_file="${source_file%.go}_test.go"
  fi

  # Check if test file already exists
  if [[ -f "$output_file" ]]; then
    echo "[skip] $output_file already exists"
    exit 0
  fi

  generate_go_test_file "$source_file" "$output_file"

  # Analysis stats
  echo ""
  echo "Analysis:"
  echo "  Package: $(grep '^package ' "$source_file" | awk '{print $2}')"
  echo "  Functions: $(analyze_go_functions "$source_file" | wc -l | xargs)"
  echo "  Branches: $(analyze_go_branches "$source_file")"
}

main "$@"